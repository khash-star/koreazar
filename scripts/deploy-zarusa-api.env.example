# Copy to scripts/deploy-zarusa-api.local.env (gitignored via *.local)
# Used by: npm run deploy:zarusa-api

# --- SFTP/SSH upload (required) ---
ZARUSA_DEPLOY_HOST=api.zarkorea.com
ZARUSA_DEPLOY_USER=your_cpanel_username
ZARUSA_DEPLOY_PORT=22
# Absolute remote directory where index.php lives (cPanel subdomain docroot)
ZARUSA_DEPLOY_REMOTE_DIR=/home/your_user/public_html/api

# Auth: SSH private key (recommended) OR password (less secure)
ZARUSA_DEPLOY_SSH_KEY=C:\Users\you\.ssh\id_rsa
# ZARUSA_DEPLOY_PASSWORD=only_if_no_key

# --- MySQL migration (optional — skip with -SkipMigration) ---
# If set, script SSHs to server and runs migration via mysql CLI on the host.
ZARUSA_DB_HOST=127.0.0.1
ZARUSA_DB_NAME=zarkorea_zarkorea
ZARUSA_DB_USER=zarkorea_user
ZARUSA_DB_PASSWORD=your_db_password
