VITE_OPENAI_API_KEY=your-openai-api-key
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Dev only: Firebase Console test phone numbers + true skips SMS reCAPTCHA locally
# VITE_FIREBASE_PHONE_TEST_MODE=true

# Include /index.php unless Apache rewrite sends / to index.php (see api/.htaccess)
VITE_API_BASE_URL=https://api.zarkorea.com/index.php

# Optional: force the active country config (KR, MN, JP). If unset, the app
# resolves the country from the URL path (e.g. /kr, /mn) and falls back to
# KR. See src/config/country.js.
# VITE_ACTIVE_COUNTRY=KR
