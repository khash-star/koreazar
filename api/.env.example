# Copy to api/.env on server (never commit .env)

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=zarkorea_zarkorea
DB_USERNAME=zarkorea_user
DB_PASSWORD=your_strong_password_here

# Set true only while debugging (shows error message in JSON)
APP_DEBUG=false

# Firebase (for Bearer ID token verification on write endpoints)
FIREBASE_WEB_API_KEY=your_firebase_web_api_key

# Optional: comma-separated Firebase UID list who can update/delete any listing
APP_ADMIN_UIDS=
