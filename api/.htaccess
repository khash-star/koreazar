# Default document: avoid "Index of /" when opening https://api.zarkorea.com/
DirectoryIndex index.php index.html

# Hide folder file listing (security)
Options -Indexes

# Pass Authorization: Bearer ... to PHP (many hosts strip it; CGI/FastCGI fix)
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteCond %{HTTP:Authorization} .
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>

# Block direct web access to secrets
<FilesMatch "^\.env$">
  Require all denied
</FilesMatch>

# Apache 2.2 fallback (if Require is not available, comment out the block above and use):
# <FilesMatch "^\.env$">
#   Order allow,deny
#   Deny from all
# </FilesMatch>
