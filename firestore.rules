rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function adminDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function adminRole() {
      return adminDoc().role;
    }

    function isSuperAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (adminRole() == 'admin' || adminRole() == 'super_admin');
    }

    function isAppAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (adminRole() == 'admin' || adminRole() == 'super_admin' ||
         adminRole() == 'country_admin' || adminRole() == 'region_admin');
    }

    // Legacy alias — global admin only (user role assignment, config)
    function isAdmin() {
      return isSuperAdmin();
    }

    function listingCountry(listing) {
      return listing.country_code is string ? listing.country_code.upper() : 'KR';
    }

    function listingRegion(listing) {
      return listing.region_code is string ? listing.region_code.lower() : '';
    }

    function adminCanModerateListing(listing) {
      return isSuperAdmin() ||
        (adminRole() == 'country_admin' &&
          adminDoc().admin_country_code is string &&
          listingCountry(listing) == adminDoc().admin_country_code.upper()) ||
        (adminRole() == 'region_admin' &&
          listingCountry(listing) == 'US' &&
          adminDoc().admin_region_code is string &&
          listingRegion(listing) == adminDoc().admin_region_code.lower());
    }

    function bannerCountry(banner) {
      return banner.country_code is string ? banner.country_code.upper() : 'KR';
    }

    function adminCanModerateBanner(banner) {
      return isSuperAdmin() ||
        (adminRole() == 'country_admin' &&
          adminDoc().admin_country_code is string &&
          bannerCountry(banner) == adminDoc().admin_country_code.upper()) ||
        (adminRole() == 'region_admin' && bannerCountry(banner) == 'US');
    }

    function adminCanManageUserProfiles() {
      return isSuperAdmin() ||
        (adminRole() == 'country_admin');
    }

    function protectedAdminFieldsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['role', 'isAdmin', 'admin_country_code', 'admin_region_code']);
    }

    // Имэйл: token.email заримдаа null биш ч "" байна — энэ үед users/{uid}.email руу шилжих ёстой.
    function authEmailLower() {
      return request.auth != null &&
        request.auth.token.email != null &&
        request.auth.token.email is string &&
        request.auth.token.email.size() > 0
        ? request.auth.token.email.lower()
        : request.auth != null &&
            exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email is string &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email.size() > 0
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email.lower()
        : '';
    }

    function userChatEmailMatches(participantEmail) {
      let em = authEmailLower();
      return em.size() > 0 &&
        participantEmail is string &&
        participantEmail.size() > 0 &&
        participantEmail.lower() == em;
    }

    function userPhoneVariantsMatch(participantEmail) {
      return request.auth != null &&
        participantEmail is string &&
        participantEmail.size() > 0 &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.phoneAuthEmails is list &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.phoneAuthEmails.hasAny([participantEmail.lower()]);
    }

    function participantEmailMatchesAuth(participantEmail) {
      return userChatEmailMatches(participantEmail) || userPhoneVariantsMatch(participantEmail);
    }

    function isConversationParticipant() {
      return request.auth != null && (
        (resource.data.participant_uids is list && resource.data.participant_uids.hasAny([request.auth.uid])) ||
        (resource.data.participant_1 is string && resource.data.participant_1.size() > 0 && participantEmailMatchesAuth(resource.data.participant_1)) ||
        (resource.data.participant_2 is string && resource.data.participant_2.size() > 0 && participantEmailMatchesAuth(resource.data.participant_2))
      );
    }

    function isMessageConversationParticipant() {
      return request.auth != null &&
        resource.data.conversation_id is string &&
        resource.data.conversation_id.size() > 0 &&
        exists(/databases/$(database)/documents/conversations/$(resource.data.conversation_id)) &&
        get(/databases/$(database)/documents/conversations/$(resource.data.conversation_id)).data.participant_uids is list &&
        get(/databases/$(database)/documents/conversations/$(resource.data.conversation_id)).data.participant_uids.hasAny([request.auth.uid]);
    }

    function isMessageSenderOrReceiver() {
      return request.auth != null && (
        isMessageConversationParticipant() ||
        (resource.data.sender_email is string && resource.data.sender_email.size() > 0 && participantEmailMatchesAuth(resource.data.sender_email)) ||
        (resource.data.receiver_email is string && resource.data.receiver_email.size() > 0 && participantEmailMatchesAuth(resource.data.receiver_email))
      );
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId
        && (!('role' in request.resource.data) || request.resource.data.role == 'user');
      allow update: if isSuperAdmin() || (
        adminCanManageUserProfiles() && protectedAdminFieldsUnchanged()
      ) || (
        request.auth.uid == userId
        && protectedAdminFieldsUnchanged()
        && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)
      );
      allow delete: if isSuperAdmin();
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.created_by == request.auth.token.email ||
        adminCanModerateListing(resource.data) ||
        (request.resource.data.views == resource.data.views + 1 &&
         request.resource.data.created_by == resource.data.created_by &&
         request.resource.data.title == resource.data.title &&
         request.resource.data.category == resource.data.category)
      );
      allow delete: if request.auth != null &&
        (resource.data.created_by == request.auth.token.email || adminCanModerateListing(resource.data));
    }

    match /banner_ads/{bannerId} {
      allow read: if true;
      allow create: if isSuperAdmin() || (
        isAppAdmin() && (
          (adminRole() == 'country_admin' && request.resource.data.country_code is string &&
            request.resource.data.country_code.upper() == adminDoc().admin_country_code.upper()) ||
          (adminRole() == 'region_admin' && request.resource.data.country_code is string &&
            request.resource.data.country_code.upper() == 'US')
        )
      );
      allow update: if isSuperAdmin() || (
        adminCanModerateBanner(resource.data) &&
        adminCanModerateBanner(request.resource.data)
      );
      allow delete: if isSuperAdmin() || adminCanModerateBanner(resource.data);
    }

    match /banner_requests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAppAdmin();
    }

    match /listing_reports/{reportId} {
      allow read: if request.auth != null && (
        isAppAdmin() ||
        (resource.data.reporter_uid == request.auth.uid) ||
        (authEmailLower().size() > 0 &&
          resource.data.reporter_email is string &&
          resource.data.reporter_email.lower() == authEmailLower())
      );
      allow create: if request.auth != null && (
        (request.resource.data.reporter_uid == request.auth.uid) ||
        (authEmailLower().size() > 0 &&
          request.resource.data.reporter_email is string &&
          request.resource.data.reporter_email.lower() == authEmailLower())
      );
      allow update, delete: if isAppAdmin();
    }

    match /feedback_messages/{feedbackId} {
      allow create: if request.auth != null && (
        (request.resource.data.user_uid == request.auth.uid) ||
        (authEmailLower().size() > 0 &&
          request.resource.data.email is string &&
          request.resource.data.email.lower() == authEmailLower())
      );
      allow read, update, delete: if isSuperAdmin();
    }

    match /saved_listings/{savedId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (
        (request.resource.data.user_uid == request.auth.uid) ||
        (authEmailLower().size() > 0 &&
          request.resource.data.created_by is string &&
          request.resource.data.created_by.lower() == authEmailLower())
      );
      allow delete: if request.auth != null && (
        (resource.data.user_uid == request.auth.uid) ||
        (authEmailLower().size() > 0 &&
          resource.data.created_by is string &&
          resource.data.created_by.lower() == authEmailLower())
      );
    }

    match /conversations/{conversationId} {
      allow read: if request.auth != null &&
        (isConversationParticipant() || isAppAdmin());
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        (isConversationParticipant() || isAppAdmin());
      allow delete: if request.auth != null &&
        (isConversationParticipant() || isAppAdmin());
    }

    match /messages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        (isMessageSenderOrReceiver() || isAppAdmin());
      allow delete: if request.auth != null &&
        (isMessageSenderOrReceiver() || isAppAdmin());
    }

    match /ai_conversations/{conversationId} {
      allow read: if request.auth != null &&
        resource.data.user_email == request.auth.token.email;
      allow list: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.user_email == request.auth.token.email;
      allow update: if request.auth != null &&
        resource.data.user_email == request.auth.token.email;
      allow delete: if request.auth != null &&
        resource.data.user_email == request.auth.token.email;
    }

    match /ai_messages/{messageId} {
      allow read: if request.auth != null &&
        resource.data.user_email == request.auth.token.email;
      allow list: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.user_email == request.auth.token.email;
      allow delete: if request.auth != null &&
        resource.data.user_email == request.auth.token.email;
    }

    match /user_push_tokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      match /devices/{deviceId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    match /ai_usage/{usageId} {
      allow get: if request.auth != null && (
        !exists(/databases/$(database)/documents/ai_usage/$(usageId)) ||
        resource.data.user_email == request.auth.token.email ||
        isSuperAdmin()
      );
      allow list: if request.auth != null;
      allow create, update: if request.auth != null &&
        request.resource.data.user_email == request.auth.token.email;
      allow delete: if request.auth != null &&
        resource.data.user_email == request.auth.token.email;
    }
  }
}
