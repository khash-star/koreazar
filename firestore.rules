rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Имэйл: token.email заримдаа null биш ч "" байна — энэ үед users/{uid}.email руу шилжих ёстой.
    function authEmailLower() {
      return request.auth != null &&
        request.auth.token.email != null &&
        request.auth.token.email is string &&
        request.auth.token.email.size() > 0
        ? request.auth.token.email.lower()
        : request.auth != null &&
            exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email is string &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email.size() > 0
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email.lower()
        : '';
    }

    // Нэг талын имэйл null/буруу төрөлтэй хуучин баримт query-ийн бүх үр дүнг permission-denied болгоно — тус бүрээр OR шалгана.
    function isConversationParticipant() {
      let em = authEmailLower();
      return request.auth != null && (
        (resource.data.participant_uids is list && resource.data.participant_uids.hasAny([request.auth.uid])) ||
        (em.size() > 0 && (
          (resource.data.participant_1 is string && resource.data.participant_1.size() > 0 && resource.data.participant_1.lower() == em) ||
          (resource.data.participant_2 is string && resource.data.participant_2.size() > 0 && resource.data.participant_2.lower() == em)
        ))
      );
    }

    function isMessageSenderOrReceiver() {
      let em = authEmailLower();
      return request.auth != null && em.size() > 0 && (
        (resource.data.sender_email is string && resource.data.sender_email.size() > 0 && resource.data.sender_email.lower() == em) ||
        (resource.data.receiver_email is string && resource.data.receiver_email.size() > 0 && resource.data.receiver_email.lower() == em)
      );
    }

    function isConversationDataParticipant(conversationData) {
      let em = authEmailLower();
      return request.auth != null && (
        (conversationData.participant_uids is list && conversationData.participant_uids.hasAny([request.auth.uid])) ||
        (em.size() > 0 && (
          (conversationData.participant_1 is string && conversationData.participant_1.size() > 0 && conversationData.participant_1.lower() == em) ||
          (conversationData.participant_2 is string && conversationData.participant_2.size() > 0 && conversationData.participant_2.lower() == em)
        ))
      );
    }

    function isConversationParticipantById(conversationId) {
      return conversationId is string &&
        conversationId.size() > 0 &&
        exists(/databases/$(database)/documents/conversations/$(conversationId)) &&
        isConversationDataParticipant(get(/databases/$(database)/documents/conversations/$(conversationId)).data);
    }

    function canReadMessage() {
      return request.auth != null && (
        isAdmin() ||
        isMessageSenderOrReceiver() ||
        isConversationParticipantById(resource.data.conversation_id)
      );
    }

    function canCreateMessage() {
      let em = authEmailLower();
      return request.auth != null &&
        request.resource.data.conversation_id is string &&
        request.resource.data.conversation_id.size() > 0 &&
        request.resource.data.sender_email is string &&
        request.resource.data.sender_email.size() > 0 &&
        request.resource.data.receiver_email is string &&
        request.resource.data.receiver_email.size() > 0 &&
        (isAdmin() || (em.size() > 0 && request.resource.data.sender_email.lower() == em)) &&
        isConversationParticipantById(request.resource.data.conversation_id);
    }
    
    // Users collection — owners cannot change role/isAdmin (no self-promotion to admin)
    match /users/{userId} {
      allow read: if true; // Anyone can read user profiles
      allow create: if request.auth != null && request.auth.uid == userId
        && (!('role' in request.resource.data) || request.resource.data.role == 'user');
      allow update: if isAdmin() || (
        request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isAdmin'])
        && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)
      );
      allow delete: if isAdmin();
    }
    
    // Listings collection
    match /listings/{listingId} {
      allow read: if true; // Anyone can read listings
      allow create: if request.auth != null;
      // Allow update if user is owner/admin
      // Also allow anyone authenticated to update views field (for view count tracking)
      allow update: if request.auth != null && (
        resource.data.created_by == request.auth.token.email || 
        isAdmin() ||
        // Allow view count increment - check if views is being incremented and other fields unchanged
        (request.resource.data.views == resource.data.views + 1 &&
         request.resource.data.created_by == resource.data.created_by &&
         request.resource.data.title == resource.data.title &&
         request.resource.data.category == resource.data.category)
      );
      allow delete: if request.auth != null && 
        (resource.data.created_by == request.auth.token.email || isAdmin());
    }
    
    // Banner ads - Admin only
    match /banner_ads/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Banner requests
    match /banner_requests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Listing reports (санал/гомдол) — email эсвэл reporter_uid (phone OTP)
    match /listing_reports/{reportId} {
      allow read: if request.auth != null && (
        isAdmin() ||
        (resource.data.reporter_uid == request.auth.uid) ||
        (authEmailLower().size() > 0 &&
          resource.data.reporter_email is string &&
          resource.data.reporter_email.lower() == authEmailLower())
      );
      allow create: if request.auth != null && (
        (request.resource.data.reporter_uid == request.auth.uid) ||
        (authEmailLower().size() > 0 &&
          request.resource.data.reporter_email is string &&
          request.resource.data.reporter_email.lower() == authEmailLower())
      );
      allow update, delete: if isAdmin();
    }

    // Footer feedback messages — email эсвэл user_uid (phone OTP)
    match /feedback_messages/{feedbackId} {
      allow create: if request.auth != null && (
        (request.resource.data.user_uid == request.auth.uid) ||
        (authEmailLower().size() > 0 &&
          request.resource.data.email is string &&
          request.resource.data.email.lower() == authEmailLower())
      );
      allow read, update, delete: if isAdmin();
    }
    
    // Saved listings — created_by/email эсвэл user_uid (phone OTP)
    match /saved_listings/{savedId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (
        (request.resource.data.user_uid == request.auth.uid) ||
        (authEmailLower().size() > 0 &&
          request.resource.data.created_by is string &&
          request.resource.data.created_by.lower() == authEmailLower())
      );
      allow delete: if request.auth != null && (
        (resource.data.user_uid == request.auth.uid) ||
        (authEmailLower().size() > 0 &&
          resource.data.created_by is string &&
          resource.data.created_by.lower() == authEmailLower())
      );
    }
    
    // Conversations
    match /conversations/{conversationId} {
      allow read: if request.auth != null && 
        (isConversationParticipant() || isAdmin());
      allow create: if request.auth != null;
      allow update: if request.auth != null && 
        (isConversationParticipant() || isAdmin());
      allow delete: if request.auth != null && 
        (isConversationParticipant() || isAdmin());
    }
    
    // Messages
    match /messages/{messageId} {
      allow read: if canReadMessage();
      allow create: if canCreateMessage();
      allow update: if request.auth != null && 
        (isMessageSenderOrReceiver() || isAdmin());
      allow delete: if request.auth != null && 
        (isMessageSenderOrReceiver() || isAdmin());
    }
    
    // AI Conversations
    match /ai_conversations/{conversationId} {
      // Allow read if user owns the conversation
      allow read: if request.auth != null && 
        resource.data.user_email == request.auth.token.email;
      // Allow list queries with where clause - Firestore will filter results
      allow list: if request.auth != null;
      // Allow create if user_email matches authenticated user
      allow create: if request.auth != null && 
        request.resource.data.user_email == request.auth.token.email;
      // Allow update if user owns the conversation
      allow update: if request.auth != null && 
        resource.data.user_email == request.auth.token.email;
      allow delete: if request.auth != null && 
        resource.data.user_email == request.auth.token.email;
    }
    
    // AI Messages
    match /ai_messages/{messageId} {
      // Allow read if user owns the message
      allow read: if request.auth != null && 
        resource.data.user_email == request.auth.token.email;
      // Allow list queries with where clause - Firestore will filter results
      allow list: if request.auth != null;
      // Allow create if user_email matches authenticated user
      allow create: if request.auth != null && 
        request.resource.data.user_email == request.auth.token.email;
      allow delete: if request.auth != null && 
        resource.data.user_email == request.auth.token.email;
    }
    
    // Expo push tokens — one doc per device under uid (chat push)
    match /user_push_tokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      match /devices/{deviceId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // App config (e.g. listingAutoApprove) - read by any auth, write by admin only
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // AI Usage Tracking
    match /ai_usage/{usageId} {
      // Allow read if document exists and user owns it or is admin
      // Also allow read if document doesn't exist (for getDoc checks)
      allow get: if request.auth != null && (
        !exists(/databases/$(database)/documents/ai_usage/$(usageId)) ||
        resource.data.user_email == request.auth.token.email ||
        isAdmin()
      );
      // Allow list queries for authenticated users
      allow list: if request.auth != null;
      // Allow create/update if user_email matches authenticated user
      allow create, update: if request.auth != null && 
        request.resource.data.user_email == request.auth.token.email;
      allow delete: if request.auth != null && 
        resource.data.user_email == request.auth.token.email;
    }
  }
}

