{
  "name": "zarkorea-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "postinstall": "patch-package",
    "prestart": "node ../scripts/sync-listings.mjs",
    "start": "expo start",
    "start:lan": "expo start --lan",
    "start:tunnel": "expo start --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eas:build:ios": "npx eas-cli build --profile development --platform ios",
    "eas:build:android": "npx eas-cli build --profile development --platform android",
    "release:ios": "npx eas-cli build --profile production --platform ios",
    "release:android": "npx eas-cli build --profile production --platform android",
    "release:submit:ios": "npx eas-cli submit --profile production --platform ios --latest",
    "release:submit:android": "npx eas-cli submit --profile production --platform android --latest",
    "release:android:us": "npx eas-cli build --profile production-us --platform android",
    "release:ios:us": "npx eas-cli build --profile production-us --platform ios",
    "submit:android:us": "npx eas-cli submit --profile production-us --platform android --latest",
    "submit:ios:us": "npx eas-cli submit --profile production-us --platform ios --latest"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/auth": "^24.0.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.5",
    "expo": "~55.0.24",
    "expo-build-properties": "~55.0.14",
    "expo-dev-client": "~55.0.34",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.10",
    "expo-image-manipulator": "~55.0.16",
    "expo-image-picker": "~55.0.20",
    "expo-linking": "~55.0.15",
    "expo-notifications": "~55.0.23",
    "expo-status-bar": "~55.0.6",
    "firebase": "^12.10.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-image-viewing": "^0.2.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "~0.7.0"
  },
  "private": true,
  "devDependencies": {
    "patch-package": "^8.0.1"
  },
  "overrides": {
    "react-native-worklets": "~0.7.0"
  }
}
