{
  "expo": {
    "name": "Zarkorea",
    "slug": "zarkorea-app",
    "scheme": "zarkorea",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-ios-1024.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/icon-ios-1024.png",
      "buildNumber": "19",
      "bundleIdentifier": "com.zarkorea.twa",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.zarkorea.twa",
      "versionCode": 22,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon-ios-1024.png",
          "color": "#E6F4FE",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "kotlinVersion": "2.1.20"
          }
        }
      ],
      "expo-image",
      [
        "expo-image-picker",
        {
          "photosPermission": "Зураг оруулахын тулд таны зургийн цомог руу нэвтрэх зөвшөөрөл хэрэгтэй."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2cccf64b-c6d9-46c3-849f-fd5f96b204ef"
      }
    }
  }
}
