{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle",
        "credentialsSource": "local"
      }
    },
    "production-us": {
      "extends": "production",
      "env": {
        "EXPO_PUBLIC_ACTIVE_COUNTRY": "US"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./play-service-account.json"
      },
      "ios": {
        "bundleIdentifier": "com.zarkorea.twa"
      }
    },
    "production-us": {
      "android": {
        "serviceAccountKeyPath": "./play-service-account.json",
        "applicationId": "com.zarusa.app"
      },
      "ios": {
        "bundleIdentifier": "com.zarusa.app"
      }
    }
  }
}
