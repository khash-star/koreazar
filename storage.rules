rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Legacy flat folder — existing production URLs keep working.
    match /images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // users/{uid}/profile/...
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // listings/{kr|us|jp}/{year}/{listingId}/...
    match /listings/{country}/{year}/{listingId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Legacy listings path (pre country/year structure)
    match /listings/{listingId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // banners/{kr|us|jp}/{bannerId}/...
    match /banners/{country}/{bannerId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Legacy flat banners path
    match /banners/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
